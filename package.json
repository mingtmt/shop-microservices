{
  "name": "shop-microservices",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=services/api-service",
    "dev:noti": "npm run dev --workspace=services/notification-service",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:noti\"",
    "format": "prettier . --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^17.0.0",
    "prettier": "^3.7.4"
  },
  "overrides": {
    "multer-storage-cloudinary": {
      "cloudinary": "^2.9.0"
    }
  }
}
